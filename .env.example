# ---------------------------------------------------------------------------
# aktienpost.ch — environment variables
# Copy this file to `.env.local` for local development; set the same values
# in the Vercel dashboard for production.
# ---------------------------------------------------------------------------

# ---- Supabase ----
# Found under Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
# Server-only — NEVER expose this to the client. Used by /api/register to
# create users and insert their profile row with RLS bypassed.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ---- Resend (transactional email) ----
# Used by /api/contact to forward the contact form and by /api/register to
# notify Oliver of new registrations. Sender domain: aktienpost.ch — must
# be verified in the Resend dashboard before first use.
RESEND_API_KEY=re_<your-key>
