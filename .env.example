# ---------------------------------------------------------------------------
# aktienpost.ch — environment variables
# Copy this file to `.env.local` for local development; set the same values
# in the Vercel dashboard for production.
# ---------------------------------------------------------------------------

# ---- Resend (transactional email) ----
# Used by /api/contact to forward the contact form and by /api/register to
# notify Oliver of new sign-ups. Sender domain: aktienpost.ch — must be
# verified in the Resend dashboard before first use.
RESEND_API_KEY=re_<your-key>

# ---- Supabase (newsletter signups) ----
# Used by /api/newsletter to insert into the newsletter_subscribers
# table. Service-role key stays server-side only — do NOT add a
# NEXT_PUBLIC_ prefix and never reference it from a client component.
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ---- Admin dashboard ----
# Shared password that gates /dashboard. Pick something long. Leave unset
# to disable the dashboard entirely (the login endpoint then responds
# with 500 "not_configured").
ADMIN_PASSWORD=<choose-a-strong-password>
